{
  "name": "nclaw",
  "version": "0.3.0",
  "description": "NeuroClaw coding agent CLI — connect any machine to your hosted NeuroClaw server",
  "bin": {
    "nclaw": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "install.sh",
    "README.md"
  ],
  "scripts": {
    "build":      "tsc",
    "dev":        "tsx src/index.tsx",
    "typecheck":  "tsc --noEmit",
    "prepublish": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": ["neuroclaw", "ai", "cli", "agent", "coding"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url":  "https://github.com/The-Code-Labz/nclaw-cli.git"
  },
  "devDependencies": {
    "@types/node":  "^20.0.0",
    "@types/react": "^17.0.0",
    "tsx":          "^4.0.0",
    "typescript":   "^5.5.0"
  },
  "dependencies": {
    "chalk":           "^4.1.2",
    "fuzzysort":       "^2.0.4",
    "ink":             "^3.2.0",
    "marked":          "^9.1.6",
    "marked-terminal": "^6.2.0",
    "react":           "^17.0.2"
  }
}
